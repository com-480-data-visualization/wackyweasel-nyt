!images/*.svg
!index.html

# Whitelist: source
!src/
!src/css/
!src/css/*.css
!src/js/
!src/js/*.js
!src/data/
!src/data/processed/
!src/data/processed/*.json

# Whitelist: process book
!process-book/
!process-book/*.md
!process-book/*.pdf
!process-book/*.typ
!process-book/*.sh

# Whitelist: scripts
!scripts/
!scripts/*.py

